; game/Card.tscn — one per physical card (ASSETS §4.2). Root extends XRToolsPickable via
; CardFace.gd, so the SAME node is grabbable/throwable AND owns its face (DESIGN §4/§6).
; Tuning here (mass, collider, impulse) is the on-device calibration surface — start from
; these and adjust in-headset (the saucer.tscn in the addon demo is the reference for feel).
; ⚠️ Open in Godot 4.7 once to assign UIDs + confirm CardFace resolves the pickable base.
[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://game/CardFace.gd" id="1_cardface"]

[sub_resource type="BoxShape3D" id="BoxShape3D_card"]
; Thin, card-shaped (10cm × 15cm × 6mm). Not paper-thin: CCD + this depth keeps the card
; inside the PlayZone box for ≥1 physics tick (finding F3, anti-tunnel).
size = Vector3(0.1, 0.15, 0.006)

[sub_resource type="QuadMesh" id="QuadMesh_card"]
size = Vector2(0.1, 0.15)

[sub_resource type="StandardMaterial3D" id="StandardMaterial3D_card"]
; Per-instance (resource_local_to_scene) so swapping one card's face never touches another
; (finding F2). Unshaded + alpha-scissor = crisp 2D face on a 3D quad. CardFace also enforces
; these at runtime; the texture is assigned by GameRoot from the per-type frames.
resource_local_to_scene = true
transparency = 2
shading_mode = 0
texture_filter = 0

[node name="Card" type="RigidBody3D"]
; Mirror the addon's working pickable collision (layer 3 = card; mask = world). XR Tools
; swaps the held card to a no-collide layer automatically, so PlayZone only fires on a
; thrown (released) card, not a held one (ASSETS §6).
collision_layer = 4
collision_mask = 196615
mass = 0.3
continuous_cd = true
freeze_mode = 1
script = ExtResource("1_cardface")
release_mode = 0

[node name="CollisionShape3D" type="CollisionShape3D" parent="."]
shape = SubResource("BoxShape3D_card")

[node name="MeshInstance3D" type="MeshInstance3D" parent="."]
mesh = SubResource("QuadMesh_card")
surface_material_override/0 = SubResource("StandardMaterial3D_card")
