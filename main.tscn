; The red felt target disc — sits on the table surface (y≈0.70) directly under the PlayZone
; trigger (same x,z and radius), so its visible circle IS the place to throw the card onto.
[node name="FeltCircle" type="MeshInstance3D" parent="GameRoot"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.702, -0.6)
mesh = SubResource("CylinderMesh_felt")

; Retro control panel: a 2D UI (Hud.tscn) on a 3D quad placed at the player's RIGHT, at
; eyeline (~1.45 m) and within arm's reach (~0.5 m) — turn right, then poke a button (or use
; the laser). The X basis is NEGATED (left-handed basis = horizontal mirror): the Viewport2Din3D
; rendered its text mirrored whichever way we faced it, so we flip the content here instead of
; rotating. Input still maps correctly — the addon's body uses the collider's affine_inverse.
; ponytail: position eyeballed off the rig math — nudge in-headset to taste.
[node name="Hud3D" parent="." instance=ExtResource("31_viewport")]
; Yawed 15°, pivoting about the left (rules) edge so it stays put and the right (button) edge
; swings backward/away — turns the panel flatter to the user's gaze. ponytail: tune the angle.
transform = Transform3D(0.4226, 0, 0.9063, 0, 1, 0, 0.9063, 0, -0.4226, 0.7383, 1.45, 0.1127)
screen_size = Vector2(0.95, 0.577)
; Unshaded so the panel shows its texture at full brightness — shaded, it went black when angled
; away from the scene light in the dim room.
unshaded = true
scene = ExtResource("32_hud")
viewport_size = Vector2(840, 510)
