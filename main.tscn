[sub_resource type="CylinderShape3D" id="CylinderShape3D_top"]
; Solid collision column up to the tabletop surface (top at world y≈0.70) — a thrown card
; lands on top and can't tunnel through. (The visible top is the thin CylinderMesh_top disc;
; this is just the physics body, so its height is free to be tall.)
radius = 0.55
height = 0.7

[sub_resource type="ShaderMaterial" id="ShaderMaterial_wall"]
shader = ExtResource("6_wall")
; No shader_parameter overrides — wall.gdshader uniform defaults are the single source of truth.
; Tune the walls by editing wall.gdshader; don't re-add overrides here (they'd mask the file).

[sub_resource type="SphereMesh" id="CylinderMesh_room"]
material = SubResource("ShaderMaterial_wall")
; Hemisphere = a real dome: curved walls arcing overhead instead of a cone's straight slope.
; radius 3.0 matches the old bottom_radius; height 3.0 = radius for a true half-sphere.
radius = 3.0
height = 3.0
is_hemisphere = true
radial_segments = 64
rings = 32

; Dark floor disc — fills the dome's open base so the ground reads as solid, not infinite void.
; Near the WorldEnvironment color so it stays unobtrusive; radius matches the dome rim (3.0).
[sub_resource type="StandardMaterial3D" id="StandardMaterial_floor"]
albedo_color = Color(0.05, 0.05, 0.07, 1)
roughness = 1.0

[sub_resource type="CylinderMesh" id="CylinderMesh_floor"]
material = SubResource("StandardMaterial_floor")
top_radius = 3.0
bottom_radius = 3.0
height = 0.01
cap_bottom = false

[sub_resource type="ShaderMaterial" id="ShaderMaterial_felt"]
shader = ExtResource("29_felt")
; felt.gdshader defaults are the single source of truth (radius 0.25 = the felt disc + trigger).

[sub_resource type="CylinderMesh" id="CylinderMesh_felt"]
material = SubResource("ShaderMaterial_felt")
top_radius = 0.25
bottom_radius = 0.25
height = 0.002

; PlayZone trigger = a cylinder matching the felt disc, tall enough to reach DOWN to the table
; surface so a card landing on the felt (not just one arcing through above it) fires the round.
[sub_resource type="CylinderShape3D" id="CylinderShape3D_zone"]
radius = 0.25
height = 0.4

